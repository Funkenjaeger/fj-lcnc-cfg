o<home_sense_toolholder> sub
	#1900=#<_coord_system>  (Save current coordinate system.)

	M5																			(Turn spindle off)

	G59.3																		(Switch temporarily to G59.3 WCS for probing)
	G10 L2 P9 X0 Y0 Z0															(Zero out work coordinate offsets in G59.3)
	
	G53 G0 Z0
	G53 G0 X#<_ini[TOOLSENSOR]X_LOC> Y#<_ini[TOOLSENSOR]Y_LOC>					(Move to tool setter position)
	G53 G0 Z#<_ini[TOOLSENSOR]Z_PROBE_START>									(Move Z  to safe height above tool setter to start probe)
	M64 P2																		(Turn on optical sensor)
	G38.3 G90 Z#<_ini[TOOLSENSOR]Z_PROBE_END> F#<_ini[TOOLSENSOR]SEARCH_VEL>	(Probe move to optical sensor)
	M65	P3																		(clear DO3 to indicate no detect)

	o200 if [#5070 EQ 1]
		; probe move succeeded
		M66 P6 L3 Q1															(Wait up to 1 second for digital input X to turn on)
		o110 if[#5399 EQ -1]
			M65	P3																(clear DO3 to indicate no detect)
			(abort,Probe contact, but not detected by optical sensor)
		o110 else
			M64 P3																(set DO3 to indicate detect)
		o110 endif
	o200 else
		; probe move failed
		M65	P3																	(clear DO3 to indicate no detect)
	o200 endif
	M5																			(Turn spindle off)
	M65 P2																		(Turn off optical sensor)
	G53 G0 Z0
	
	(Restore original coordinate system. G54 to G59.2 only)
	o100 if[#1900 EQ 540]
	  G54
	o100 endif
	o101 if[#1900 EQ 550]
	  G55
	o101 endif
	o102 if[#1900 EQ 560]
	  G56
	o102 endif
	o103 if[#1900 EQ 570]
	  G57
	o103 endif
	o104 if[#1900 EQ 580]
	  G58
	o104 endif
	o105 if[#1900 EQ 590]
	  G59
	o105 endif
	o106 if[#1900 EQ 591]
	  G59.1
	o106 endif
	o107 if[#1900 EQ 592]
	  G59.2
	o107 endif
o<home_sense_toolholder> endsub
M2
