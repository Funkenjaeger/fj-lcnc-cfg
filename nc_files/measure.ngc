o<measure> sub

#1900=#<_coord_system>  (Save current coordinate system.)
#<coordinate_system> = #5220 (Current coordinate system number: 1=G54, 9=G59.3)
#<wcs_z_varnumber> = [5203 + [20* #5220]] (5223 for G54, 5243 for G55, etc)
#<wcs_z> = #[#<wcs_z_varnumber>]
M5                                                                 (Turn spindle off)

o500 if[#<_current_tool> EQ #<_selected_tool>]                     (Same tool as before so no need to do anything.)

o500 else 
	(This is a different tool.)
	#<method>=1			(Proceed)
	M64 P1				(Turn on spindle purge air)
	
	o200 if [#<_current_tool> EQ 0]
		(No tool loaded yet)
		M102
		M66 E20 L0	
		#<method> = #5399
		(print,sub M102 returned #5399)
		o210 if [#<method> EQ 2]
			(Invalidate WCS Z offset)
			#[#<wcs_z_varnumber>] = 999
		o210 endif
		o211 if [#<method> LT 0]
			(abort,User cancelled M6 via dialog)
		o211 endif
		(If method=<3>adjust, nothing to do yet)
	o200 endif
	
	G90 G0                                                          (Absolute distance mode Rapid move)
	G53 Z#<_ini[TOOLSENSOR]Z_SAFE>	   	 (Change Z Position)
	
	G59.3															(Switch temporarily to G59.3 WCS for probing)
	G10 L2 P9 X0 Y0 Z0												(Zero out work coordinate offsets in G59.3)
	
	o201 if [#<_hal[tool-change-mode]>]
		; AUTOMATIC TOOL CHANGE
		#<pocket_current_x> = [#<_ini[TOOL_CHANGE]POCKET_1_X> + [[#<_current_tool> - 1] * #<_ini[TOOL_CHANGE]POCKET_DELTA_X>]]
		#<pocket_selected_x> = [#<_ini[TOOL_CHANGE]POCKET_1_X> + [[#<_selected_tool> - 1] * #<_ini[TOOL_CHANGE]POCKET_DELTA_X>]]
		#<pocket_approach_y> = [#<_ini[TOOL_CHANGE]POCKET_Y> + #<_ini[TOOL_CHANGE]POCKET_SAFE_MOVE_Y>]
		#<pocket_safe_z> = [#<_ini[TOOL_CHANGE]POCKET_Z> + #<_ini[TOOL_CHANGE]POCKET_SAFE_RETRACT_Z>]
		G53 G0 X#<pocket_current_x> Y#<pocket_approach_y>								(Rapid XY to approach position for current tool's pocket)
		G53 G0 Z#<_ini[TOOL_CHANGE]POCKET_Z> 											(Rapid Z to pocket height)
		G53 G1 Y#<_ini[TOOL_CHANGE]POCKET_Y> F#<_ini[TOOL_CHANGE]APPROACH_VELOCITY>		(Slot tool into pocket)
		M64 P0 																			(Release drawbar)
		G4 P#<_ini[TOOL_CHANGE]DWELL_TIME>												(Wait for drawbar release)
		G53 G0 Z#<pocket_safe_z>														(Rapid Z to clear tool holders)
		G53 G0 X#<pocket_selected_x>													(Rapid X over selected tool)
		G53 G1 Z#<_ini[TOOL_CHANGE]POCKET_Z> F#<_ini[TOOL_CHANGE]APPROACH_VELOCITY>		(Move Z onto selected tool)
		M65 P0 																			(Engage drawbar)
		G4 P#<_ini[TOOL_CHANGE]DWELL_TIME>												(Wait for drawbar engagement)
		G53 G1 Y#<pocket_approach_y>													(Slot tool out of pocket)
		G53 G0 Z0																		(Rapid retract Z)
	o201 else
		; MANUAL TOOL CHANGE
		G53 X#<_ini[TOOL_CHANGE]MANUAL_CHANGE_LOC_X> Y#<_ini[TOOL_CHANGE]MANUAL_CHANGE_LOC_Y>   	 	(Move XY to manual change position)
		M6 T#<_selected_tool>										   (Do built-in M6 routine - pops up prompt)
	o201 endif
	
	G43                                                             (Enable tool length compensation)
	
	;G49 (Cancel tool length compensation)

	(Measure tool to get offset)
	G53 X#<_ini[TOOLSENSOR]X_LOC> Y#<_ini[TOOLSENSOR]Y_LOC>      (Move to tool setter postion)
	G53 Z#<_ini[TOOLSENSOR]Z_PROBE_START>                        (Move Z  to safe height above tool setter to start probe)
	S500 M4														 (Run spindle in reverse at minimum speed)
	G91                                                          (Incremental Mode)
	G38.2 Z#<_ini[TOOLSENSOR]Z_PROBE_DISTANCE> F#<_ini[TOOLSENSOR]SEARCH_VEL>            (Measure Gross)
	G38.5 Z#<_ini[TOOLSENSOR]Z_BACKOFF> F#<_ini[TOOLSENSOR]SEARCH_VEL>
	;G43.1 Z0                                                     (Dynamic Tool Length Offset set to zero.)
	G0 Z#<_ini[TOOLSENSOR]Z_BACKOFF>                                            	(Z up)	
	G38.2 Z[-2*#<_ini[TOOLSENSOR]Z_BACKOFF>] F#<_ini[TOOLSENSOR]PROBE_VEL>				(Measure fine)
	
	#<new_tlo> = #5063
	G43.1 Z#<new_tlo>
	G38.5 Z#<_ini[TOOLSENSOR]Z_BACKOFF> F#<_ini[TOOLSENSOR]SEARCH_VEL>
	G1 Z.1 F#<_ini[TOOLSENSOR]SEARCH_VEL>
	M5 
	G90 G0                                                       (Absolute distance mode, Rapid move)
	G53 Z#<_ini[TOOLSENSOR]Z_SAFE>                                                   (Z up to safe position)
	M61 Q#<_selected_tool>											(Set current tool)
	
	M65 P1				(Turn off spindle purge air)
	
	o300 if [#<method> EQ 3]
		(Adjust WCS Z using old value & new tool length offset)
		(print,old WCS_Z=#<wcs_z>, new TLO=#<new_tlo>, new WCS_Z=[#<wcs_z>-#<new_tlo>])
		#[#<wcs_z_varnumber>] = [#<wcs_z>-#<new_tlo>]
	o300 endif
	
	(Restore orginal coordinate system. G54 to G59.2 only)
	o100 if[#1900 EQ 540]
	  G54
	o100 endif
	o101 if[#1900 EQ 550]
	  G55
	o101 endif
	o102 if[#1900 EQ 560]
	  G56
	o102 endif
	o103 if[#1900 EQ 570]
	  G57
	o103 endif
	o104 if[#1900 EQ 580]
	  G58
	o104 endif
	o105 if[#1900 EQ 590]
	  G59
	o105 endif
	o106 if[#1900 EQ 591]
	  G59.1
	o106 endif
	o107 if[#1900 EQ 592]
	  G59.2
	o107 endif
o500 endif
o<measure> endsub
M2

